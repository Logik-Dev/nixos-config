{
  "annotations": { "list": [] },
  "title": "NVIDIA GPU",
  "uid": "nvidia-gpu",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["gpu", "nvidia"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "GPU Utilization",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "nvidia_gpu_utilization", "legendFormat": "GPU%" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "type": "stat",
      "title": "GPU Temperature",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "nvidia_gpu_temperature_celsius", "legendFormat": "Temp" } ],
      "fieldConfig": { "defaults": { "unit": "celsius" } }
    },
    {
      "type": "stat",
      "title": "GPU Memory",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "nvidia_gpu_memory_total_bytes", "legendFormat": "Total" },
        { "expr": "nvidia_gpu_memory_used_bytes", "legendFormat": "Used" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "GPU Utilization Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "nvidia_gpu_utilization", "legendFormat": "GPU%" },
        { "expr": "nvidia_gpu_memory_utilization", "legendFormat": "Mem%" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    }
  ]
}